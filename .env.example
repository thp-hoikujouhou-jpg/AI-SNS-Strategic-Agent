BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_PASSWORD=your_app_password
GEMINI_API_KEY=your_gemini_api_key

# 使用するGeminiモデル (例: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp)
GEMINI_MODEL=gemini-1.5-flash

# 探したい職業（例：エンジニア、デザイナー、イラストレーターなど）
TARGET_PROFESSION=エンジニア

# いいねやコメントを行うかどうかの設定 (True または False)
LIKE_POSTS=True
COMMENT_POSTS=True
