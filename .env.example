BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_PASSWORD=your_app_password

# Vercel AI Gateway (OpenAI-compatible) Settings
VERCEL_GATEWAY_API_KEY=your_gateway_api_key
VERCEL_GATEWAY_URL=https://gateway.ai.vercel.com/v1/projects/YOUR_PROJECT_ID/gateways/YOUR_GATEWAY_ID
VERCEL_GATEWAY_MODEL=google/gemini-1.5-flash

# 探したい職業（例：エンジニア、デザイナー、イラストレーターなど）
TARGET_PROFESSION=エンジニア

# いいねやコメントを行うかどうかの設定 (True または False)
LIKE_POSTS=True
COMMENT_POSTS=True
